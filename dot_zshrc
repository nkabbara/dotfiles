# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# History file location
HISTFILE=~/.zsh_history
# Number of commands to remember in memory
HISTSIZE=100
# Number of commands to save to file
SAVEHIST=100
# Append history to file instead of overwriting
setopt APPEND_HISTORY
# Share history between all sessions
setopt SHARE_HISTORY
# Don't record duplicate commands
setopt HIST_IGNORE_DUPS
# Ignore commands that start with a space
setopt HIST_IGNORE_SPACE
bindkey '^R' history-incremental-search-backward


# exports
export oc=/opt/homebrew/bin/nvim
export EDITOR=/opt/homebrew/bin/nvim
export FZF_DEFAULT_COMMAND='rg --files'
export KANATA_TRAY_CONFIG_DIR="/Users/nkabbara/.config/kanata/"
export MANPATH=$MANPATH:/opt/local/share/man
export INFOPATH=$INFOPATH:/opt/local/share/info
export PATH=/opt/local/bin:/opt/local/sbin:/usr/local/bin/node:$PATH
export PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"
export PATH="$HOME/.rbenv/bin:$PATH"
export PATH="/usr/local/go-bin:$PATH"
export PATH="/opt/homebrew/bin:$PATH"
export GOPATH=$HOME/dev/go
if (( $+commands[go] )); then
  export PATH="$PATH:$(go env GOPATH)/bin"
fi
export PATH=/Users/nkabbara/.opencode/bin:$PATH


# alias
alias kanata-custom='nohup sudo -E kanata-tray &> /dev/null &'
alias l='ls -lrthG'
alias vi='nvim -p'
alias vim='nvim -p'
alias b='bundle exec '
alias gist='gh gist create '
alias g='git'
alias sudo='sudo --preserve-env=PATH'
alias oc='opencode'
alias cm='chezmoi'


# functions
function cdg () {
   cdargs -f ~/.cdargs "$1" && cd "`cat "$HOME/.cdargsresult"`" ;
}

# source
[ -f /opt/homebrew/opt/asdf/libexec/asdf.sh ] && source /opt/homebrew/opt/asdf/libexec/asdf.sh
[ -f ~/powerlevel10k/powerlevel10k.zsh-theme ] && source ~/powerlevel10k/powerlevel10k.zsh-theme

# other
set -o vi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

if [ -z "$SSH_AUTH_SOCK" ]; then
    eval "$(ssh-agent -s)"
fi
